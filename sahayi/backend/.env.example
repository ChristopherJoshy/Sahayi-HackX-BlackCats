# ─────────────────────────────────────────────────
# SAHAYI BACKEND — ENVIRONMENT VARIABLES
# Team: Black Cats | HackX
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────

# GEMINI (vision only — cheap multimodal; used for prescription image extraction)
GEMINI_VISION_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-2.0-flash-lite

# SARVAM AI (text LLM + Malayalam STT + TTS)
# All agent text reasoning (incl. WhatsApp text) routes through Sarvam's
# OpenAI-compatible Indic LLM. sarvam-30b = fastest + cheapest. sarvam-105b
# = higher quality (recommended for the voice companion). Leave
# SARVAM_LLM_MODEL empty to fall back to the code default (currently sarvam-105b).
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_LLM_MODEL=sarvam-105b
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
# Default/fallback language for TTS. STT auto-detects the spoken language (language_code="auto").
SARVAM_LANGUAGE=ml-IN
SARVAM_TTS_SPEAKER=ritu

# TWILIO (Voice + WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxx
TWILIO_WEBHOOK_BASE=your_ngrok_url_here

# DATABASE
DATABASE_URL=sqlite+aiosqlite:///./sahayi.db

# CHROMADB (RAG Vector Store)
CHROMA_PERSIST_DIR=./rag/chroma_store
CHROMA_COLLECTION_NAME=sahayi_medical_kb

# PUBMED API (free — no key needed, but set email)
PUBMED_EMAIL=your_email@example.com
PUBMED_MAX_RESULTS=3

# RISK SCORING THRESHOLDS
RISK_YELLOW_THRESHOLD=0.4
RISK_RED_THRESHOLD=0.7
ANOMALY_Z_SCORE_THRESHOLD=2.0
DOCTOR_ESCALATION_HOURS=3

# EMERGENCY DOCTOR PHONE — called for EVERY patient escalation (per clinic).
# Falls back to the per-patient doctor_contact.phone when set.
DOCTOR_EMERGENCY_PHONE=+916282257804

# DASHBOARD SECURITY
DASHBOARD_AUTH_HEADER=X-Sahayi-Doctor-Token
DASHBOARD_SHARED_TOKEN=hackathon_demo_token

# SERVER
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
SECRET_KEY=your_secret_key_here_min_32_chars
FRONTEND_URL=http://localhost:5173
